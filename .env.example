# ---- LLM (Anthropic Claude) --------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Model driving requirement understanding, quote extraction, and negotiation.
LLM_MODEL=claude-opus-4-8

# ---- ERP integration ---------------------------------------------------------
# Product catalog is fetched from here; quotations & invoices are pushed back.
ERP_BASE_URL=https://erp.example.com/api/v1
ERP_API_KEY=erp-xxxxxxxxxxxxxxxxxxxx

# ---- WhatsApp channel (e.g. Meta Cloud API / Twilio) -------------------------
WHATSAPP_API_BASE=https://graph.facebook.com/v21.0
WHATSAPP_PHONE_NUMBER_ID=000000000000000
WHATSAPP_ACCESS_TOKEN=whatsapp-xxxxxxxxxxxxxxxxxxxx

# ---- Email channel (IMAP in / SMTP out) --------------------------------------
EMAIL_IMAP_HOST=imap.example.com
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_USERNAME=sales@example.com
EMAIL_PASSWORD=change-me

# ---- Commercial defaults -----------------------------------------------------
# Fallback markup applied when no per-item markup is supplied (e.g. 0.18 = 18%).
DEFAULT_MARKUP_PCT=0.18
